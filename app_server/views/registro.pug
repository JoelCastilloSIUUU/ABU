extends layout

block content
  .container-fluid.bg-white(style="min-height: 100dvh; padding: 0;")
    .row.justify-content-center.m-0
      .col-12.col-md-6.col-lg-4.p-4.text-center
        
        .mt-5.mb-4
          .mx-auto.rounded-circle.d-flex.justify-content-center.align-items-center.mb-3(style="width: 100px; height: 100px; background-color: #FF8C00;")
            i.bi.bi-person-plus-fill.text-white(style="font-size: 3.5rem;")
          
          h1.fw-bold(style="color: #D35400; font-size: 2.2rem;")= title
          p.text-muted(style="font-size: 1.1rem;")= subtitle
        
        form.text-start.mt-5
          .mb-4
            label.form-label.fw-bold.text-secondary(for='name') Tu nombre
            input#name.form-control.form-control-lg(type='text', placeholder='Escribe tu nombre', style="border-radius: 1rem; border: 2px solid #FF8C00; padding: 15px;")
          
          .mb-5
            label.form-label.fw-bold.text-secondary(for='password') Contraseña
            input#password.form-control.form-control-lg(type='password', placeholder='Escribe tu contraseña', style="border-radius: 1rem; border: 2px solid #FF8C00; padding: 15px;")
        
          button.btn.btn-lg.w-100.text-white.fw-bold.shadow-sm(type='submit', style="background-color: #FF8C00; border-radius: 1rem; padding: 15px; font-size: 1.2rem;")= botonPrincipal
        
        .mt-auto.pb-4
          //- Este enlace nos regresa al login (ruta '/')
          a.d-block.mt-5.text-decoration-none.fw-bold(href="/", style="color: #FF4500; font-size: 1rem;")= loginTexto